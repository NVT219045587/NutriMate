# This is just an example for placeholder and future setup purpose
# The .env file is in .gitignore and must NEVER be committed.
#
# Jenkins: store these as Secret Text credentials with the IDs shown below
# and reference them in the Jenkinsfile via credentials('nutrimate-jwt-secret')
# and credentials('nutrimate-mssql-sa-password').

# ── JWT signing key ───────────────────────────────────────────────────────────
# Jenkins credential ID: nutrimate-jwt-secret
# Requirement: Minimum 32 random characters
JWT_SECRET=CHANGE_ME_replace_with_a_long_random_string_min_32_chars

# ── SQL Server SA password ───────────────────────────────────────────────────
# Jenkins credential ID: nutrimate-mssql-sa-password
# Requirements: ≥8 chars, uppercase, lowercase, digit, symbol.
MSSQL_SA_PASSWORD=Change@Me1234!

# ── Optional: pin a specific Docker image tag for rollback ───────────────────
IMAGE_TAG=latest
